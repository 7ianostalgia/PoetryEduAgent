# 运行模式：只允许 dev 或 gpu
RUN_MODE=dev
DEV_STAGE_DELAY_SECONDS=0.03

# Web 服务
HOST=0.0.0.0
PORT=7860
FRONTEND_STATIC_DIR=frontend/static

# 数据与输出
POETRY_DB_PATH=data/poetry_edu.db
POETRY_RUNTIME_DB_PATH=data/runtime/learning_runtime.db
OUTPUT_DIR=outputs

# Conda 与隔离模型环境
CONDA_EXE=conda
QWEN_CONDA_ENV=poetryedu-qwen14b-awq
KOLORS_CONDA_ENV=poetryedu-kolors
VISION_CONDA_ENV=poetryedu-qwen-vl

# gpu 模式模型路径
LOCAL_LLM_MODEL=
KOLORS_MODEL=
VISION_MODEL=

# DeepSeek-V4-Flash
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
